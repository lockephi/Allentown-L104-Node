<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.l104.nano-daemon-swift</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/carolalvarez/Applications/Allentown-L104-Node/L104SwiftApp/.build/release/L104NanoDaemon</string>
        <string>--tick</string>
        <string>3</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/carolalvarez/Applications/Allentown-L104-Node</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>L104_ROOT</key>
        <string>/Users/carolalvarez/Applications/Allentown-L104-Node</string>
        <key>RESONANCE</key>
        <string>527.5184818492612</string>
        <key>L104_NANO_DAEMON</key>
