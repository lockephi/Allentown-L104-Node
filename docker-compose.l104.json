{
  "version": "3.9",
  "services": {
    "sovereign_us_east_1": {
      "image": "l104/quantum-daemon:latest",
      "container_name": "Sovereign-US-East-1",
      "hostname": "Sovereign-US-East-1",
      "environment": {
        "L104_NODE_ID": "daemon-us-east-001",
        "L104_NODE_NAME": "Sovereign-US-East-1",
        "L104_REGION": "us-east-1",
        "L104_ROLE": "sovereign",
        "L104_MAX_QUBITS": "26",
        "L104_QUANTUM_TOPOLOGY": "all_to_all",
        "L104_ENABLE_QKD": "True",
        "L104_ENABLE_ERROR_CORRECTION": "True",
        "L104_PORT": "10401",
        "L104_TELEMETRY_PORT": "9091"
      },
      "ports": [
        "10401:10401",
        "9091:9091"
      ],
      "networks": [
        "l104_quantum_network"
      ],
      "restart_policy": {
        "condition": "on-failure",
        "delay": "5s",
        "max_attempts": 5
      },
      "healthcheck": {
        "test": [
          "CMD",
          "curl",
          "-f",
          "http://localhost:9091/health"
        ],
        "interval": "30s",
        "timeout": "10s",
        "retries": 3
      }
    },
